---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHeroCarousel from '../components/HomeHeroCarousel.astro';
import HomeVideosStrip from '../components/HomeVideosStrip.astro';
import DocLinkBanner from '../components/DocLinkBanner.astro';
import SiteJsonLd from '../components/SiteJsonLd.astro';
import { homeSlides, homeSeo } from '../data/homeSlides';
import { siteConfig } from '../config/site';
---

<BaseLayout
  title={homeSeo.title}
  description={homeSeo.description}
  keywords={homeSeo.keywords}
  canonicalPath="/"
>
  <SiteJsonLd slot="head" />
  <HomeHeroCarousel slides={homeSlides} />

  <HomeVideosStrip />

  <DocLinkBanner message="Tutorials, FAQs, app downloads, and product guides are on docs.openterface.com." />

  <section class="py-10 md:py-16">
    <div class="mx-auto max-w-6xl px-4 text-center">
      <h2 class="section-title">KVM-over-USB pour les professionnels de l'informatique</h2>
      <p class="section-subtitle mx-auto max-w-2xl text-base md:text-lg">
        Matériel open source et ultra-compact avec des applications multiplateformes. Contrôlez des machines sans écran depuis l'appareil que vous portez déjà sur vous.
      </p>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 sm:gap-6 lg:grid-cols-4">
        <a href="/products/keymod/" class="card hover:border-primary-dark hover:shadow-md">
          <h3 class="font-semibold">KeyMod</h3>
          <p class="mt-2 text-sm text-muted">Téléphone comme clavier et pavé tactile</p>
        </a>
        <a href="/products/kvm-go/" class="card hover:border-primary-dark hover:shadow-md">
          <h3 class="font-semibold">KVM-GO</h3>
          <p class="mt-2 text-sm text-muted">KVM au format porte-clés</p>
        </a>
        <a href="/products/minikvm/" class="card hover:border-primary-dark hover:shadow-md">
          <h3 class="font-semibold">Mini-KVM</h3>
          <p class="mt-2 text-sm text-muted">Ordinateur portable comme console KVM</p>
        </a>
        <a href="/products/accessories/" class="card hover:border-primary-dark hover:shadow-md">
          <h3 class="font-semibold">Accessoires</h3>
          <p class="mt-2 text-sm text-muted">Câbles et sacoche de transport</p>
        </a>
      </div>
      <a href={siteConfig.links.appOverview} class="btn btn-primary mt-8" target="_blank" rel="noopener">
        Télécharger l'application Openterface
      </a>
    </div>
  </section>
</BaseLayout>
