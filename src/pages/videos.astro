---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocLinkBanner from '../components/DocLinkBanner.astro';
import { legacyPath } from '../config/site';
---

<BaseLayout
  title="Vidéos"
  description="Démos de produits Openterface, tutoriels et avis sur YouTube."
  canonicalPath="/videos/"
>
  <DocLinkBanner message="La grille complète des vidéos YouTube avec filtres se trouve sur le site d'origine jusqu'à ce que nous portions le système vidéo." />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h1 class="text-4xl font-bold">Vidéos</h1>
      <p class="mt-4 text-lg text-muted">
        Regardez les démos de produits, les guides de configuration et les avis de la communauté pour les produits Openterface KVM et KeyMod.
      </p>
      <a href={legacyPath('/videos/')} class="btn btn-primary mt-8" target="_blank" rel="noopener">
        Parcourir toutes les vidéos →
      </a>
    </div>
  </section>
</BaseLayout>
