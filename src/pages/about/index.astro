---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocLinkBanner from '../../components/DocLinkBanner.astro';
import { docsPath } from '../../config/site';
---

<BaseLayout
  title="À propos d'Openterface"
  description="Découvrez Openterface — des solutions KVM-over-USB open source conçues par TechxArtisan."
  ogImageAlt="Solutions KVM-over-USB open source Openterface par TechxArtisan"
  canonicalPath="/about/"
>
  <DocLinkBanner />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-4xl font-bold">À propos d'Openterface</h1>
      <p class="mt-6 text-lg leading-relaxed text-muted">
        Openterface conçoit des outils KVM-over-USB ultra-compacts et open source pour les professionnels de l'informatique, les développeurs et les makers.
        Du Mini-KVM financé par participation au KVM-GO de la taille d'un porte-clés, en passant par la série programmable KeyMod, notre mission est
        de simplifier le contrôle des ordinateurs sans écran sans équipement encombrant ni réseau complexe.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href={docsPath('/about/about-us/')} class="btn btn-secondary" target="_blank" rel="noopener">
          À propos de nous →
        </a>
        <a href={docsPath('/about/compliance/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Conformité →
        </a>
        <a href={docsPath('/about/community/')} class="btn btn-secondary" target="_blank" rel="noopener">
          Communauté →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
