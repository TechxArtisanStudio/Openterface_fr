---
import BaseLayout from '../layouts/BaseLayout.astro';
import DocLinkBanner from '../components/DocLinkBanner.astro';
import { legacyPath } from '../config/site';
---

<BaseLayout
  title="Cas d'utilisation"
  description="Exemples d'utilisation réelle des produits KVM-over-USB Openterface."
  canonicalPath="/use-cases/"
>
  <DocLinkBanner />
  <section class="py-16">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-4xl font-bold">Cas d'utilisation</h1>
      <p class="mt-4 text-lg text-muted">
        Les outils Openterface excellent chaque fois que vous avez besoin de contrôler un ordinateur sans écran ou difficile d'accès sans écran ni clavier dédié.
      </p>
      <ul class="mt-8 space-y-4">
        {
          [
            'Visites de centres de données et de colocation',
            'Administration de serveurs personnels et NAS',
            'Mise en route d\'appareils embarqués et SBC',
            'Maintenance de bornes et d\'affichage dynamique',
            'Interventions informatiques sur le terrain et consulting',
          ].map((item) => (
            <li class="card">{item}</li>
          ))
        }
      </ul>
      <a href={legacyPath('/use-cases/')} class="btn btn-secondary mt-8" target="_blank" rel="noopener">
        Voir la galerie complète des cas d'utilisation →
      </a>
    </div>
  </section>
</BaseLayout>
